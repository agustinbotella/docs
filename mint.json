{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Guayaba AI",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#16A34A",
    "light": "#4ADE80",
    "dark": "#15803D",
    "background": {
      "light": "#FFFFFF",
      "dark": "#0F1117"
    }
  },
  "topbarLinks": [
    {
      "name": "guayaba.ai",
      "url": "https://guayaba.ai"
    }
  ],
  "topbarCtaButton": {

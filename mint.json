    }
  },
  "navigation": [
    {
      "group": "Getting Started",
      "pages": [
        "introduction",
        "authentication"
      ]
    },
    {
      "group": "Campaigns",
      "pages": [
        "api-reference/campaigns/list"
      ]
    },
    {
      "group": "Contacts",
      "pages": [
        "api-reference/contacts/create",
        "api-reference/contacts/list",
        "api-reference/contacts/statuses",
        "api-reference/contacts/update"
      ]
    }
  ],
  "footerSocials": {
    "website": "https://guayaba.ai"
  }
}
